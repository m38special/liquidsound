# ============================================================
# LiQUiD SOUND — Environment Variables
# Copy this file to .env.local (never commit .env.local)
# ============================================================

# ---- Database (Neon PostgreSQL) ----------------------------
# Connection string from Neon console: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/liquid_sound?sslmode=require

# ---- Auth (Clerk) ------------------------------------------
# Get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---- Storage (Cloudflare R2) --------------------------------
# Account ID and credentials from Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_R2_BUCKET_NAME=liquid-sound-media
# Public URL for R2 bucket (set after configuring custom domain or public access)
NEXT_PUBLIC_R2_PUBLIC_URL=https://media.liquid-sound.com

# ---- Queue / Cache (Upstash Redis) --------------------------
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Redis connection string for BullMQ (ioredis) — use the rediss:// endpoint from Upstash
UPSTASH_REDIS_URL=rediss://default:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.upstash.io:6379

# ---- Video Pipeline (Remotion Lambda / AWS) -----------------
# AWS account: 395671099412 (LiQUiDSOUND app group: us-east-2)
# IAM user must have the Remotion Lambda policy applied — see docs/aws-remotion-setup.md
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-2
# Deployed: remotion-render-4-0-441-mem2048mb-disk2048mb-240sec (us-east-2)
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-4-0-441-mem2048mb-disk2048mb-240sec
# Site deployed: s3://remotionlambda-useast2-kohj42amea/sites/liquidsound-v1/
REMOTION_LAMBDA_SERVE_URL=https://remotionlambda-useast2-kohj42amea.s3.us-east-2.amazonaws.com/sites/liquidsound-v1/index.html
# HMAC secret for validating render completion webhooks
RENDER_WEBHOOK_SECRET=generate-a-strong-random-secret-here

# ---- Email (Resend) ----------------------------------------
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# From address must be verified in Resend (e.g. noreply@yourdomain.com)
RESEND_FROM_EMAIL=noreply@liquid-sound.com

# ---- App Config --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
